# Variables d'environnement - Exemple de configuration
# Copiez ce fichier en .env et modifiez les valeurs selon votre environnement

# ====================
# Configuration Flask
# ====================
FLASK_ENV=development
FLASK_APP=run.py
DEBUG=True

# Clé secrète pour les sessions et CSRF
# IMPORTANT: Générez une clé aléatoire forte en production
# Exemple: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production

# ====================
# Base de données
# ====================
# Développement (SQLite)
DATABASE_URL=sqlite:///marches_locaux.db

# Production (PostgreSQL - décommenter et configurer)
# DATABASE_URL=postgresql://username:password@localhost:5432/marches_locaux

# ====================
# Logging
# ====================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ====================
# Rate Limiting
# ====================
# Développement (en mémoire)
RATELIMIT_STORAGE_URL=memory://

# Production (Redis - décommenter et configurer)
# RATELIMIT_STORAGE_URL=redis://localhost:6379

# ====================
# SocketIO
# ====================
# Origines autorisées pour CORS (développement: *)
SOCKETIO_CORS_ALLOWED_ORIGINS=*

# Production: spécifiez les domaines
# SOCKETIO_CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com

# ====================
# Email (optionnel)
# ====================
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password

# ====================
# Authentification (optionnel)
# ====================
# Google OAuth
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
